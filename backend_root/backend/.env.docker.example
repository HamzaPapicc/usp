# ----------------------------
# Django core
# ----------------------------
# Use a long random value (>=32 bytes recommended for JWT HS256).
DJANGO_SECRET_KEY=change-me-with-a-long-random-secret-at-least-32-bytes
DJANGO_DEBUG=False
# Keep False for production. For demo setups without dedicated media server,
# set True to let Django serve /media files.
DJANGO_SERVE_MEDIA=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_TRUST_X_FORWARDED_PROTO=True

# For local Docker without HTTPS keep these false.
# For real HTTPS deployment set them to True.
DJANGO_AUTH_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False

FRONTEND_BASE_URL=http://localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost

# ----------------------------
# Database (PostgreSQL in compose)
# ----------------------------
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=job_ads
DJANGO_DB_USER=job_ads
DJANGO_DB_PASSWORD=job_ads_password
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432

# ----------------------------
# Email
# ----------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@localhost

# Resend SMTP (uncomment and fill when ready)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxx
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False